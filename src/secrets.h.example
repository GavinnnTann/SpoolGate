#pragma once

// Copy this file to secrets.h (gitignored) and fill in real values.

// Set to 1 for WPA2-Enterprise/802.1X (e.g. SUTD campus WiFi, confirmed as the
// Phase 2 target), 0 for plain WPA2-Personal (e.g. home WiFi, used for Phase 1
// acceptance testing). This is the only thing that needs to change between phases
// — see src/net/uplink.cpp.
#define UPLINK_AUTH_ENTERPRISE 0

// --- Upstream network (STA) ---
#define UPLINK_SSID "your-upstream-ssid"

// Used when UPLINK_AUTH_ENTERPRISE == 0.
#define UPLINK_PASS "your-upstream-password"

// Used when UPLINK_AUTH_ENTERPRISE == 1. Identity is the outer EAP identity sent
// in the clear before the TLS tunnel establishes — normally the same as username
// unless the network expects an anonymous outer identity (check with campus IT if
// logins fail with a valid username/password).
#define UPLINK_EAP_IDENTITY "your-student-id"
#define UPLINK_EAP_USERNAME "your-student-id"
#define UPLINK_EAP_PASSWORD "your-network-password"

// --- SoftAP the printer joins ---
#define PRINTERNET_SSID "PrinterNet"
#define PRINTERNET_PASS "change-me-min-8-chars"
